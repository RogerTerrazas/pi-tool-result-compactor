{
  "name": "pi-tool-result-compactor",
  "version": "1.0.0",
  "description": "A Pi extension that compacts verbose tool outputs with an inspector model before they enter agent context.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "coding-agent",
    "tool-output",
    "compaction"
  ],
  "license": "MIT",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "echo 'No build step required; Pi loads the TypeScript extension directly.'"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.10",
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3"
  }
}
